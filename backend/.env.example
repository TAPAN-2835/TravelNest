# ==========================================
# Backend Environment Configuration
# ==========================================

# 🔹 Local Development Environment
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# Database Connections (Local Docker)
DATABASE_URL=postgresql://travelnest_user:travelnest_pass@localhost:5432/travelnest
MONGODB_URI=mongodb://localhost:27017/travelnest
REDIS_URL=redis://localhost:6379

# 🔹 Production Environment (AWS EC2)
# PORT=5000
# NODE_ENV=production
# FRONTEND_URL=https://www.travelnest.com
# AI_SERVICE_URL=http://ai-service:8000
# 
# # Database Connections (AWS RDS / Atlas / ElastiCache)
# DATABASE_URL=postgresql://user:pass@mydb.rds.amazonaws.com:5432/travelnest
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/travelnest
# REDIS_URL=redis://my-elasticache.amazonaws.com:6379

# AWS Credentials
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
# SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/12345/travelnest-notifications

# Security
JWT_SECRET=super_secret_key
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret
